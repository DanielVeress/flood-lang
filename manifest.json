{
  "manifest_version": 3,
  "name": "FloodLang",
  "version": "0.1.1",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "type": "module"
    }
  ],
  "background": {
    "scripts": ["src/background/index.js"],
    "type": "module"
  }
}
